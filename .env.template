# ============================================================
# Demografy Insights Chatbot — Environment Variables Template
# ============================================================
# 1. Copy this file: cp .env.template .env
# 2. Fill in your real values in .env
# 3. NEVER commit .env to GitHub

# --- Google BigQuery ---
# Path to your downloaded service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=path/to/your-service-account.json

# GCP project ID (always "demografy" for this project)
BIGQUERY_PROJECT=demografy

# --- Gemini AI ---
# Get your free key at: https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-here

# --- LangSmith (Observability) ---
# Get your key at: https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=demografy-chatbot
